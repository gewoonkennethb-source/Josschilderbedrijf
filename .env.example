# Facebook Graph API configuratie
# Verkrijg een Page Access Token via https://developers.facebook.com/
# 1. Maak een Facebook App aan
# 2. Voeg de Facebook Login product toe
# 3. Genereer een Page Access Token met pages_read_content permissie
# 4. Verleng de token naar een long-lived token

FACEBOOK_PAGE_ID=100054292670798
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token_here

# Optioneel: gebruik mock data in development
USE_MOCK_FACEBOOK_DATA=true
